# =============================================================================
# LLM Job Tracker API – Configuration tutorial
# =============================================================================
# Copy this file to .env and fill in values. See comments for each variable.
# =============================================================================

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
# Full connection URI. With Docker: mongodb://mongo:27017
# Local: mongodb://localhost:27017
MONGODB_URI=mongodb://mongo:27017

# Database name
MONGODB_DB=jobtracker

# Collection name for job applications
MONGODB_COLLECTION=applications

# -----------------------------------------------------------------------------
# Redis (Celery broker and result backend)
# -----------------------------------------------------------------------------
# With Docker: redis://redis:6379/0
# Local: redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# LLM backend
# -----------------------------------------------------------------------------
# Options: mock | ollama
# - mock: no API keys, deterministic template output (default)
# - ollama: local Ollama server (e.g. ollama run llama3)
LLM_BACKEND=mock

# Only used when LLM_BACKEND=ollama
# With Ollama on host: http://host.docker.internal:11434 (Docker) or http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# API (optional)
# -----------------------------------------------------------------------------
# Host to bind (0.0.0.0 for Docker)
API_HOST=0.0.0.0
# Port
API_PORT=8000

# Comma-separated origins for CORS (e.g. http://localhost:3000). Leave empty to disable.
CORS_ORIGINS=
